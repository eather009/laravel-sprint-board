{
    "name": "eather009/laravel-sprint-board",
    "description": "Standalone Laravel Sprint Board API package — sprints, members, and linked issues with a swappable tracker (default: Backlog).",
    "type": "library",
    "keywords": [
        "laravel",
        "sprint",
        "agile",
        "backlog",
        "api"
    ],
    "homepage": "https://github.com/eather009/laravel-sprint-board",
    "license": "MIT",
    "authors": [
        {
            "name": "Iftekhar Ahmed Eather",
            "homepage": "https://github.com/eather009",
            "role": "Owner"
        }
    ],
    "support": {
        "issues": "https://github.com/eather009/laravel-sprint-board/issues",
        "source": "https://github.com/eather009/laravel-sprint-board"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Eather009\\LaravelSprintBoard\\": "src/",
            "Eather009\\LaravelSprintBoard\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eather009\\LaravelSprintBoard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eather009\\LaravelSprintBoard\\LaravelSprintBoardServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "pint": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
